{
  "name": "mizan",
  "version": "0.1.0",
  "description": "Local-first personal finance — self-hosted alternative to Monarch Money",
  "license": "MIT",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.server.json && cp -r server/src/db/migrations dist/server/src/db/ && vite build",
    "start": "node dist/server/src/index.js",
    "db:migrate": "tsx server/src/db/migrate.ts"
  },
  "dependencies": {
    "plaid": "^41.0.0",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.474.0",
    "morgan": "^1.10.0",
    "node-machine-id": "^1.1.12",
    "node-forge": "^1.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "recharts": "^2.15.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.7",
    "@types/node-forge": "^1.3.11",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
